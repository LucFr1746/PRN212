<Window x:Class="WPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFApp"
        mc:Ignorable="d"
        Title="Product Management Console" Height="650" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#161726"
        Foreground="#ffffff"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header bar -->
            <RowDefinition Height="65"/>
            <!-- Main Content -->
            <RowDefinition Height="*"/>
            <!-- Footer Action Buttons -->
            <RowDefinition Height="75"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1e1e2f" BorderThickness="0,0,0,1" BorderBrush="#2d2e3f" Padding="25,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Product Management" Foreground="#ffffff" FontSize="22" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    <Border Background="#3f405c" CornerRadius="4" Padding="8,4" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Admin Console" Foreground="#00d2fc" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="25">
            <Grid.ColumnDefinitions>
                <!-- Form inputs -->
                <ColumnDefinition Width="360"/>
                <!-- Vertical divider -->
                <ColumnDefinition Width="25"/>
                <!-- DataGrid -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Form Panel -->
            <Border Grid.Column="0" Background="#1e1e2f" CornerRadius="12" Padding="20" BorderThickness="1" BorderBrush="#2d2e3f">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Product Details" Foreground="#ffffff" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

                        <!-- Product ID -->
                        <TextBlock Text="Product ID" Foreground="#8e90a6" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Border Background="#252639" CornerRadius="6" BorderThickness="1" BorderBrush="#3f405c" Height="36" Margin="0,0,0,15">
                            <TextBox x:Name="txtProductID" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     Foreground="#8e90a6" 
                                     FontSize="13" 
                                     VerticalContentAlignment="Center" 
                                     Margin="10,0" 
                                     IsReadOnly="True"/>
                        </Border>

                        <!-- Product Name -->
                        <TextBlock Text="Product Name" Foreground="#8e90a6" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Border Background="#0f172a" CornerRadius="6" BorderThickness="1" BorderBrush="#3f405c" Height="36" Margin="0,0,0,15">
                            <TextBox x:Name="txtProductName" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     Foreground="#ffffff" 
                                     FontSize="13" 
                                     VerticalContentAlignment="Center" 
                                     Margin="10,0"
                                     CaretBrush="#ffffff"/>
                        </Border>

                        <!-- Price -->
                        <TextBlock Text="Price" Foreground="#8e90a6" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Border Background="#0f172a" CornerRadius="6" BorderThickness="1" BorderBrush="#3f405c" Height="36" Margin="0,0,0,15">
                            <TextBox x:Name="txtPrice" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     Foreground="#ffffff" 
                                     FontSize="13" 
                                     VerticalContentAlignment="Center" 
                                     Margin="10,0"
                                     CaretBrush="#ffffff"/>
                        </Border>

                        <!-- Units in Stock -->
                        <TextBlock Text="Units In Stock" Foreground="#8e90a6" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Border Background="#0f172a" CornerRadius="6" BorderThickness="1" BorderBrush="#3f405c" Height="36" Margin="0,0,0,15">
                            <TextBox x:Name="txtUnitsInStock" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     Foreground="#ffffff" 
                                     FontSize="13" 
                                     VerticalContentAlignment="Center" 
                                     Margin="10,0"
                                     CaretBrush="#ffffff"/>
                        </Border>

                        <!-- Category -->
                        <TextBlock Text="Category" Foreground="#8e90a6" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Border Background="#0f172a" CornerRadius="6" BorderThickness="1" BorderBrush="#3f405c" Height="36" Margin="0,0,0,15">
                            <ComboBox x:Name="cboCategory" 
                                      Background="#0f172a" 
                                      BorderThickness="0" 
                                      Foreground="#ffffff" 
                                      FontSize="13" 
                                      VerticalContentAlignment="Center" 
                                      Margin="5,0"
                                      DisplayMemberPath="CategoryName"
                                      SelectedValuePath="CategoryId">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0f172a"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
                                </ComboBox.Resources>
                            </ComboBox>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- DataGrid Panel -->
            <Border Grid.Column="2" Background="#1e1e2f" CornerRadius="12" Padding="15" BorderThickness="1" BorderBrush="#2d2e3f">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Products Repository" Foreground="#ffffff" FontSize="16" FontWeight="Bold" Margin="5,0,0,15" Grid.Row="0"/>

                    <DataGrid x:Name="dgData" 
                              Grid.Row="1"
                              AutoGenerateColumns="False" 
                              Background="Transparent" 
                              BorderThickness="0" 
                              HeadersVisibility="Column"
                              RowHeaderWidth="0" 
                              GridLinesVisibility="None"
                              IsReadOnly="True" 
                              SelectionMode="Single"
                              SelectionChanged="dgData_SelectionChanged"
                              AlternatingRowBackground="#161726"
                              RowBackground="#1e1e2f"
                              Foreground="#ffffff"
                              FontSize="13"
                              CanUserAddRows="False">
                        
                        <DataGrid.Resources>
                            <!-- Column Header Style -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#252639"/>
                                <Setter Property="Foreground" Value="#a2a5b9"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,12"/>
                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter Property="BorderBrush" Value="#2d2e3f"/>
                            </Style>
                            <!-- Row Style -->
                            <Style TargetType="DataGridRow">
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3f405c"/>
                                        <Setter Property="Foreground" Value="#00d2fc"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#292a3f"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <!-- Cell Style -->
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ProductId" Binding="{Binding ProductId}" Width="80"/>
                            <DataGridTextColumn Header="ProductName" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="CategoryId" Binding="{Binding CategoryId}" Width="80"/>
                            <DataGridTextColumn Header="UnitsInStock" Binding="{Binding UnitsInStock}" Width="95"/>
                            <DataGridTextColumn Header="UnitPrice" Binding="{Binding UnitPrice, StringFormat={}{0:F4}}" Width="110"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category.CategoryName}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="#1e1e2f" BorderThickness="0,1,0,0" BorderBrush="#2d2e3f" Padding="25,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    
                    <!-- Create Button -->
                    <Button x:Name="btnCreate" Content="Create" Click="btnCreate_Click" Height="40" Width="120" Margin="0,0,12,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="8" Background="#0080ff" x:Name="border">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="White" TextBlock.FontWeight="Bold"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#0066cc"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Update Button -->
                    <Button x:Name="btnUpdate" Content="Update" Click="btnUpdate_Click" Height="40" Width="120" Margin="0,0,12,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="8" Background="#10ac84" x:Name="border">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="White" TextBlock.FontWeight="Bold"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#0d8f6e"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Delete Button -->
                    <Button x:Name="btnDelete" Content="Delete" Click="btnDelete_Click" Height="40" Width="120" Margin="0,0,12,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="8" Background="#ee5253" x:Name="border">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="White" TextBlock.FontWeight="Bold"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#d63031"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Close Button -->
                    <Button x:Name="btnClose" Content="Close" Click="btnClose_Click" Height="40" Width="120" Margin="0,0,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="8" Background="#f39c12" x:Name="border">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="White" TextBlock.FontWeight="Bold"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#d35400"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
