<Window x:Class="MyStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyStore"
        mc:Ignorable="d"
        Title="Manage Categories" Height="500" Width="450"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Category Information Panel -->
        <Border Grid.Row="0" Background="#A7D5E8" Padding="15">
            <StackPanel>
                <TextBlock Text="Category Information" 
                           Foreground="Red" 
                           FontSize="26" 
                           FontWeight="Normal" 
                           FontFamily="Segoe UI"
                           Margin="0,0,0,10"/>

                <TextBlock Text="CategoryID" 
                           FontSize="13" 
                           FontFamily="Segoe UI"
                           Margin="0,0,0,3"/>
                <TextBox x:Name="txtCategoryID" 
                         FontSize="14" 
                         FontFamily="Segoe UI"
                         Padding="3" 
                         Margin="0,0,0,12" 
                         IsReadOnly="True" 
                         Background="#F0F0F0"/>

                <TextBlock Text="Category Name" 
                           FontSize="13" 
                           FontFamily="Segoe UI"
                           Margin="0,0,0,3"/>
                <TextBox x:Name="txtCategoryName" 
                         FontSize="14" 
                         FontFamily="Segoe UI"
                         Padding="3" 
                         Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnInsert" Grid.Column="0" Content="Insert" Margin="5,0" Padding="10,4" Click="btnInsert_Click" Height="28"/>
                    <Button x:Name="btnUpdate" Grid.Column="1" Content="Update" Margin="5,0" Padding="10,4" Click="btnUpdate_Click" Height="28"/>
                    <Button x:Name="btnDelete" Grid.Column="2" Content="Delete" Margin="5,0" Padding="10,4" Click="btnDelete_Click" Height="28"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Categories List Grid -->
        <DataGrid x:Name="dgCategories" 
                  Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="dgCategories_SelectionChanged"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="White"
                  BorderThickness="0,1,0,0"
                  BorderBrush="#CCCCCC">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Category ID" Binding="{Binding CategoryId}" Width="150"/>
                <DataGridTextColumn Header="Category Name" Binding="{Binding CategoryName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
