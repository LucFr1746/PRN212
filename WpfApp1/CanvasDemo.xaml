<Page x:Class="WpfApp1.CanvasDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CanvasDemo">

    <Grid Background="#1E1E2F">
        <DockPanel LastChildFill="True">
            <!-- Top Bar: Navigation & Title -->
            <Border Height="60" Background="#2A2A40" DockPanel.Dock="Top" Padding="15,0">
                <DockPanel LastChildFill="False">
                    <Button x:Name="BtnBack" Content="⬅ Quay lại" Click="BtnBack_Click" DockPanel.Dock="Left" Background="Transparent" Foreground="#A0A0B0" BorderThickness="0" FontSize="14" Cursor="Hand" VerticalAlignment="Center"/>
                    <TextBlock Text="Demo Canvas" Foreground="White" FontSize="18" FontWeight="Bold" DockPanel.Dock="Left" Margin="20,0,0,0" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Main Canvas Area -->
            <Border Margin="20" Background="#252538" CornerRadius="8" Padding="10">
                <Canvas Background="#1A1A2E">
                    <!-- Instruction note -->
                    <TextBlock Text="Tọa độ Tuyệt đối (Canvas.Left, Canvas.Top)" Canvas.Left="20" Canvas.Top="20" Foreground="#8FA0B5" FontSize="14" FontWeight="Bold"/>

                    <!-- Label (X=50, Y=80) -->
                    <TextBlock Text="Nhãn ở (Left=50, Top=80):" Canvas.Left="50" Canvas.Top="80" Foreground="White" FontSize="14"/>

                    <!-- TextBox (Left=250, Top=75) -->
                    <TextBox Text="Input ở (Left=250, Top=75)" Canvas.Left="250" Canvas.Top="75" Width="220" Background="#1E1E2F" Foreground="White" BorderBrush="#4A90E2" Padding="6"/>

                    <!-- Button 1 (Left=50, Top=140) -->
                    <Button Content="Nút 1 (Left=50, Top=140)" Canvas.Left="50" Canvas.Top="140" Width="180" Height="40" Background="#4A90E2" Foreground="White" BorderThickness="0" FontWeight="Bold"/>

                    <!-- Button 2 (Left=260, Top=140) -->
                    <Button Content="Nút 2 (Left=260, Top=140)" Canvas.Left="260" Canvas.Top="140" Width="180" Height="40" Background="#E24A4A" Foreground="White" BorderThickness="0" FontWeight="Bold"/>

                    <!-- Element using Canvas.Right and Canvas.Bottom (Right=30, Bottom=30) -->
                    <Border Canvas.Right="30" Canvas.Bottom="30" Width="200" Height="100" Background="#2A2A40" BorderBrush="#FFCC00" BorderThickness="1" Padding="10">
                        <TextBlock Text="Góc Dưới Phải&#x0a;(Right=30, Bottom=30)&#x0a;Cực kỳ linh hoạt!" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                    </Border>
                </Canvas>
            </Border>
        </DockPanel>
    </Grid>
</Page>
