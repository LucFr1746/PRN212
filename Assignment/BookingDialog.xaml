<Window x:Class="Assignment.BookingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Booking Reservation Information" 
        Height="680" Width="760"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Booking Reservation Details" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,15"/>

        <!-- Top Section: Main Reservation Info Card -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Customer:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,10,0"/>
                <ComboBox x:Name="cbCustomer" Grid.Column="1" Height="32" DisplayMemberPath="EmailAddress" SelectedValuePath="CustomerId" VerticalContentAlignment="Center" Margin="0,0,20,12"/>

                <TextBlock Text="Booking Date:" Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,10,0"/>
                <DatePicker x:Name="dpBookingDate" Grid.Column="3" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,12"/>

                <TextBlock Text="Status:" Grid.Row="1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,10,0"/>
                <ComboBox x:Name="cbStatus" Grid.Row="1" Grid.Column="1" Height="32" VerticalContentAlignment="Center" Margin="0,0,20,0">
                    <ComboBoxItem Content="Confirmed" Tag="1"/>
                    <ComboBoxItem Content="Pending" Tag="0"/>
                </ComboBox>

                <TextBlock Text="Total Price:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,10,0"/>
                <TextBox x:Name="txtTotalPrice" Grid.Row="1" Grid.Column="3" Height="32" IsReadOnly="True" Background="#F1F5F9" Foreground="#4F46E5" FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- Middle Section: Rooms Booked Table Card -->
        <GroupBox Header="Rooms Booked (Details)" Grid.Row="2" Margin="0,0,0,15" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="dgDetails" BorderThickness="0" Margin="0,0,0,5" Height="140">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Room Number" Binding="{Binding Room.RoomNumber}" Width="150"/>
                        <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate, StringFormat=yyyy-MM-dd}" Width="160"/>
                        <DataGridTextColumn Header="End Date" Binding="{Binding EndDate, StringFormat=yyyy-MM-dd}" Width="160"/>
                        <DataGridTextColumn Header="Actual Price" Binding="{Binding ActualPrice, StringFormat=C0}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Content="Remove Selected Room" Style="{StaticResource SecondaryButton}" Grid.Row="1" Width="180" Height="30" HorizontalAlignment="Right" Margin="10,5,10,10" Click="BtnRemoveDetail_Click" Foreground="#EF4444"/>
            </Grid>
        </GroupBox>

        <!-- Bottom Section: Add Room Form Card -->
        <GroupBox Header="Add Room to Booking" Grid.Row="3" Margin="0,0,0,15" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Room:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="5,5,10,12"/>
                <ComboBox x:Name="cbRoom" Grid.Column="1" Height="32" DisplayMemberPath="RoomNumber" SelectedValuePath="RoomId" SelectionChanged="CbRoom_SelectionChanged" VerticalContentAlignment="Center" Margin="0,5,20,12"/>

                <TextBlock Text="Actual Price:" Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,5,10,12"/>
                <TextBox x:Name="txtActualPrice" Grid.Column="3" Height="32" VerticalContentAlignment="Center" Margin="0,5,0,12"/>

                <TextBlock Text="Start Date:" Grid.Row="1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="5,5,10,5"/>
                <DatePicker x:Name="dpStart" Grid.Row="1" Grid.Column="1" Height="32" VerticalContentAlignment="Center" Margin="0,5,20,5"/>

                <TextBlock Text="End Date:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,5,10,5"/>
                <Grid Grid.Row="1" Grid.Column="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <DatePicker x:Name="dpEnd" Height="32" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                    <Button Content="Add" Foreground="White" Grid.Column="1" Width="80" Height="32" Click="BtnAddDetail_Click"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Main Save / Cancel Actions -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Save Reservation" Foreground="White" Height="36" Margin="0,0,8,0" Click="BtnSave_Click" IsDefault="True"/>
            <Button Grid.Column="1" Content="Cancel" Style="{StaticResource SecondaryButton}" Height="36" Margin="8,0,0,0" Click="BtnCancel_Click" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
