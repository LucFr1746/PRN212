<Window x:Class="Assignment.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotel Management System Dashboard" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <Border Background="#1E293B" Padding="20,12" BorderThickness="0,0,0,1" BorderBrush="#0F172A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M19 4H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-8 14H9v-2h2v2zm0-4H9v-2h2v2zm0-4H9V8h2v2zm4 8h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V8h2v2z" 
                          Fill="White" 
                          Width="20" 
                          Height="20" 
                          Stretch="Uniform" 
                          VerticalAlignment="Center" 
                          Margin="0,0,10,0"/>
                    <TextBlock x:Name="txtWelcome" Text="Welcome, User" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="Logout" Grid.Column="1" Style="{StaticResource SecondaryButton}" Width="90" Height="30" Click="BtnLogout_Click" Background="#334155" Foreground="White"/>
            </Grid>
        </Border>

        <!-- Content Frame -->
        <Grid Grid.Row="1" Margin="20">
            <!-- ADMIN LAYOUT -->
            <TabControl x:Name="adminTabControl" Visibility="Collapsed">
                <!-- Customers Tab -->
                <TabItem Header="Customers">
                    <Grid Margin="10,15,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Search Box Card -->
                        <Border Style="{StaticResource CardBorder}" Padding="15,10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Search Customer:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,15,0" Foreground="#475569"/>
                                <TextBox x:Name="txtSearchCustomer" Grid.Column="1" Height="32" Padding="8,0" VerticalContentAlignment="Center" Tag="Enter name or email..."/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="15,0,0,0">
                                    <Button Content="Search" Foreground="White" Width="90" Click="BtnSearchCustomer_Click" Margin="0,0,8,0"/>
                                    <Button Content="Reset" Style="{StaticResource SecondaryButton}" Width="80" Click="BtnClearCustomer_Click" Margin="0,0,8,0"/>
                                    <Button Content="Reload" Style="{StaticResource SecondaryButton}" Width="80" Click="BtnReloadCustomer_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Data List Card -->
                        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0" Margin="0,0,0,15">
                            <DataGrid x:Name="dgCustomers" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding CustomerId}" Width="60"/>
                                    <DataGridTextColumn Header="Full Name" Binding="{Binding CustomerFullName}" Width="*"/>
                                    <DataGridTextColumn Header="Telephone" Binding="{Binding Telephone}" Width="140"/>
                                    <DataGridTextColumn Header="Email Address" Binding="{Binding EmailAddress}" Width="240"/>
                                    <DataGridTextColumn Header="Birthday" Binding="{Binding CustomerBirthday, StringFormat=yyyy-MM-dd}" Width="120"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding CustomerStatus}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Action Bar -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Add Customer" Foreground="White" Width="140" Click="BtnAddCustomer_Click" Margin="0,0,10,0"/>
                            <Button Content="Edit Details" Style="{StaticResource OutlineButton}" Width="120" Click="BtnEditCustomer_Click" Margin="0,0,10,0"/>
                            <Button Content="Remove" Style="{StaticResource SecondaryButton}" Width="100" Click="BtnDeleteCustomer_Click" Foreground="#EF4444"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- Rooms Tab -->
                <TabItem Header="Rooms">
                    <Grid Margin="10,15,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Search Box Card -->
                        <Border Style="{StaticResource CardBorder}" Padding="15,10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Search Room:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,15,0" Foreground="#475569"/>
                                <TextBox x:Name="txtSearchRoom" Grid.Column="1" Height="32" Padding="8,0" VerticalContentAlignment="Center" Tag="Enter room number..."/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="15,0,0,0">
                                    <Button Content="Search" Foreground="White" Width="90" Click="BtnSearchRoom_Click" Margin="0,0,8,0"/>
                                    <Button Content="Reset" Style="{StaticResource SecondaryButton}" Width="80" Click="BtnClearRoom_Click" Margin="0,0,8,0"/>
                                    <Button Content="Reload" Style="{StaticResource SecondaryButton}" Width="80" Click="BtnReloadRoom_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Data List Card -->
                        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0" Margin="0,0,0,15">
                            <DataGrid x:Name="dgRooms" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding RoomId}" Width="60"/>
                                    <DataGridTextColumn Header="Room Number" Binding="{Binding RoomNumber}" Width="120"/>
                                    <DataGridTextColumn Header="Room Type" Binding="{Binding RoomType.RoomTypeName}" Width="180"/>
                                    <DataGridTextColumn Header="Max Capacity" Binding="{Binding RoomMaxCapacity}" Width="120"/>
                                    <DataGridTextColumn Header="Price Per Day" Binding="{Binding RoomPricePerDay, StringFormat=C0}" Width="140"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding RoomStatus}" Width="100"/>
                                    <DataGridTextColumn Header="Description" Binding="{Binding RoomDetailDescription}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Action Bar -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Add New Room" Foreground="White" Width="145" Click="BtnAddRoom_Click" Margin="0,0,10,0"/>
                            <Button Content="Edit Room" Style="{StaticResource OutlineButton}" Width="120" Click="BtnEditRoom_Click" Margin="0,0,10,0"/>
                            <Button Content="Remove" Style="{StaticResource SecondaryButton}" Width="100" Click="BtnDeleteRoom_Click" Foreground="#EF4444"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- Reservations Tab -->
                <TabItem Header="Booking Reservations">
                    <Grid Margin="10,15,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Search Box Card -->
                        <Border Style="{StaticResource CardBorder}" Padding="15,10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Search Email:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,15,0" Foreground="#475569"/>
                                <TextBox x:Name="txtSearchBooking" Grid.Column="1" Height="32" Padding="8,0" VerticalContentAlignment="Center" Tag="Enter customer email..."/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="15,0,0,0">
                                    <Button Content="Search" Foreground="White" Width="90" Click="BtnSearchBooking_Click" Margin="0,0,8,0"/>
                                    <Button Content="Reset" Style="{StaticResource SecondaryButton}" Width="80" Click="BtnClearBooking_Click" Margin="0,0,8,0"/>
                                    <Button Content="Reload" Style="{StaticResource SecondaryButton}" Width="80" Click="BtnReloadBooking_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Data List Card -->
                        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0" Margin="0,0,0,15">
                            <DataGrid x:Name="dgBookings" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Reservation ID" Binding="{Binding BookingReservationId}" Width="120"/>
                                    <DataGridTextColumn Header="Customer Email" Binding="{Binding Customer.EmailAddress}" Width="*"/>
                                    <DataGridTextColumn Header="Booking Date" Binding="{Binding BookingDate, StringFormat=yyyy-MM-dd}" Width="160"/>
                                    <DataGridTextColumn Header="Total Price" Binding="{Binding TotalPrice, StringFormat=C0}" Width="160"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding BookingStatus}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Action Bar -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Add Reservation" Foreground="White" Width="160" Click="BtnAddBooking_Click" Margin="0,0,10,0"/>
                            <Button Content="Edit Reservation" Style="{StaticResource OutlineButton}" Width="140" Click="BtnEditBooking_Click" Margin="0,0,10,0"/>
                            <Button Content="Remove" Style="{StaticResource SecondaryButton}" Width="100" Click="BtnDeleteBooking_Click" Foreground="#EF4444"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- Statistics Tab -->
                <TabItem Header="Reports &amp; Statistics">
                    <Grid Margin="10,15,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Filter Parameters Card -->
                        <Border Style="{StaticResource CardBorder}" Padding="15,10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="From:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,8,0"/>
                                <DatePicker x:Name="dpStart" Grid.Column="1" Width="160" Height="30" VerticalAlignment="Center"/>

                                <TextBlock Text="To:" Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="20,0,8,0"/>
                                <DatePicker x:Name="dpEnd" Grid.Column="3" Width="160" Height="30" VerticalAlignment="Center"/>

                                <Button Content="Generate Report" Foreground="White" Grid.Column="4" Width="150" HorizontalAlignment="Left" Margin="25,0,0,0" Click="BtnGenerateReport_Click"/>
                            </Grid>
                        </Border>

                        <!-- Summary Cards Row -->
                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Card 1: Bookings Count -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="#EEF2F6" Width="50" Height="50" CornerRadius="25" Margin="0,0,15,0">
                                        <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Total Bookings" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="txtTotalBookings" Text="0" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Card 2: Revenue -->
                            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="#E0E7FF" Width="50" Height="50" CornerRadius="25" Margin="0,0,15,0">
                                        <TextBlock Text="💰" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Total Revenue" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="txtTotalRevenue" Text="$0" FontSize="24" FontWeight="Bold" Foreground="#4F46E5" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Data List Card -->
                        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
                            <DataGrid x:Name="dgReport" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Reservation ID" Binding="{Binding BookingReservationId}" Width="120"/>
                                    <DataGridTextColumn Header="Customer Name" Binding="{Binding BookingReservation.Customer.CustomerFullName}" Width="*"/>
                                    <DataGridTextColumn Header="Room Number" Binding="{Binding Room.RoomNumber}" Width="120"/>
                                    <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate, StringFormat=yyyy-MM-dd}" Width="140"/>
                                    <DataGridTextColumn Header="End Date" Binding="{Binding EndDate, StringFormat=yyyy-MM-dd}" Width="140"/>
                                    <DataGridTextColumn Header="Actual Price" Binding="{Binding ActualPrice, StringFormat=C0}" Width="160"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- CUSTOMER LAYOUT -->
            <TabControl x:Name="customerTabControl" Visibility="Collapsed">
                <!-- My Profile Tab -->
                <TabItem Header="My Profile">
                    <Grid Margin="10,15,10,10">
                        <Border Style="{StaticResource CardBorder}" HorizontalAlignment="Left" Width="600" Height="420" Padding="30">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Full Name -->
                                <TextBlock Text="Full Name" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,15"/>
                                <TextBox x:Name="txtCustName" Grid.Column="1" Height="34" Margin="0,0,0,15" Padding="10,0" VerticalContentAlignment="Center"/>

                                <!-- Telephone -->
                                <TextBlock Grid.Row="1" Text="Telephone" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,15"/>
                                <TextBox x:Name="txtCustPhone" Grid.Row="1" Grid.Column="1" Height="34" Margin="0,0,0,15" Padding="10,0" VerticalContentAlignment="Center"/>

                                <!-- Email -->
                                <TextBlock Grid.Row="2" Text="Email Address" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,15"/>
                                <TextBox x:Name="txtCustEmail" Grid.Row="2" Grid.Column="1" Height="34" Margin="0,0,0,15" Padding="10,0" VerticalContentAlignment="Center" IsReadOnly="True" Background="#F1F5F9" Foreground="#64748B"/>

                                <!-- Birthday -->
                                <TextBlock Grid.Row="3" Text="Birthday" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,15"/>
                                <DatePicker x:Name="dpCustBirthday" Grid.Row="3" Grid.Column="1" Height="34" Margin="0,0,0,15" VerticalAlignment="Center"/>

                                <!-- Password -->
                                <TextBlock Grid.Row="4" Text="Password" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,15"/>
                                <TextBox x:Name="txtCustPassword" Grid.Row="4" Grid.Column="1" Height="34" Margin="0,0,0,15" Padding="10,0" VerticalContentAlignment="Center"/>

                                <!-- Update Button -->
                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="Update Profile" Foreground="White" Width="160" Height="36" Click="BtnUpdateProfile_Click"/>
                                    <Button Content="Reload Profile" Style="{StaticResource SecondaryButton}" Width="130" Height="36" Margin="10,0,0,0" Click="BtnReloadProfile_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Booking History Tab -->
                <TabItem Header="Booking History">
                    <Grid Margin="10,15,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Button Content="Refresh History" Style="{StaticResource SecondaryButton}" Width="140" Height="30" Margin="0,0,0,12" HorizontalAlignment="Left" Click="BtnReloadCustHistory_Click"/>
                        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
                            <DataGrid x:Name="dgCustHistory" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Reservation ID" Binding="{Binding BookingReservationId}" Width="150"/>
                                    <DataGridTextColumn Header="Booking Date" Binding="{Binding BookingDate, StringFormat=yyyy-MM-dd}" Width="200"/>
                                    <DataGridTextColumn Header="Total Price" Binding="{Binding TotalPrice, StringFormat=C0}" Width="200"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding BookingStatus}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0" Padding="15,10" Background="#F1F5F9">
            <TextBlock Text="FU Mini Hotel Management System © 2026 - Đoàn Thế Lực - DE200523" HorizontalAlignment="Center" Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
