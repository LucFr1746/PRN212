<Window x:Class="Assignment.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login - FU Mini Hotel Management System" 
        Height="420" Width="440"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Style="{StaticResource CardBorder}" Width="360" Height="320" Padding="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Welcome Back" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               Foreground="#0F172A"/>
                    <TextBlock Text="Sign in to your account to continue" 
                               FontSize="12" 
                               HorizontalAlignment="Center" 
                               Foreground="#64748B"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Input fields -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,5">
                    <TextBlock Text="Email Address" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="#334155" 
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="txtEmail" 
                             Margin="0,0,0,15"
                             Tag="Enter your email..."/>

                    <TextBlock Text="Password" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="#334155" 
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="txtPassword" 
                                 Margin="0,0,0,5"/>
                </StackPanel>

                <!-- Action buttons -->
                <Grid Grid.Row="2" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnLogin" 
                            Grid.Column="0"
                            Content="Sign In" 
                            Foreground="White"
                            Margin="0,0,8,0" 
                            Click="BtnLogin_Click" 
                            IsDefault="True"/>
                    <Button x:Name="btnCancel" 
                            Grid.Column="1"
                            Content="Exit" 
                            Style="{StaticResource SecondaryButton}" 
                            Margin="8,0,0,0" 
                            Click="BtnCancel_Click" 
                            IsCancel="True"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
