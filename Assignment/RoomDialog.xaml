<Window x:Class="Assignment.RoomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room Information" 
        Height="540" Width="440"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock x:Name="txtTitle" Text="Room Details" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,15"/>

        <!-- Form fields inside a card border -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Room Number -->
                    <TextBlock Text="Room Number" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtRoomNumber" Margin="0,0,0,12"/>

                    <!-- Room Type -->
                    <TextBlock Text="Room Type" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cbRoomType" Height="32" DisplayMemberPath="RoomTypeName" SelectedValuePath="RoomTypeId" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                    <!-- Room Max Capacity -->
                    <TextBlock Text="Max Capacity" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCapacity" Margin="0,0,0,12"/>

                    <!-- Room Price Per Day -->
                    <TextBlock Text="Price Per Day" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtPrice" Margin="0,0,0,12"/>

                    <!-- Room Status -->
                    <TextBlock Text="Status" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cbStatus" Height="32" Margin="0,0,0,12" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Active / Available" Tag="1"/>
                        <ComboBoxItem Content="Inactive / Unavailable" Tag="0"/>
                    </ComboBox>

                    <!-- Room Detail Description -->
                    <TextBlock Text="Description" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtDescription" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="5,3"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Save Room Details" Foreground="White" Margin="0,0,8,0" Click="BtnSave_Click" IsDefault="True"/>
            <Button Grid.Column="1" Content="Cancel" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BtnCancel_Click" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
